{
  "name": "stickerport-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:cloudflare": "npm run build:cloudflare && cd dist/pages && WRANGLER_WRITE_LOGS=false WRANGLER_LOG_PATH=../../.wrangler/wrangler.log ../../node_modules/.bin/wrangler pages dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:cloudflare": "npm run build && node scripts/prepare-cloudflare-pages.mjs",
    "deploy:cloudflare": "npm run build:cloudflare && cd dist/pages && WRANGLER_WRITE_LOGS=false WRANGLER_LOG_PATH=../../.wrangler/wrangler.log ../../node_modules/.bin/wrangler pages deploy --branch main",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build:cloudflare && node --test tests/*.test.mjs",
    "verify:production": "node scripts/verify-production-assets.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "mixpanel-browser": "2.70.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
